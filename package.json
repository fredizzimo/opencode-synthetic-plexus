{
  "name": "opencode-synthetic-plexus",
  "version": "1.0.0",
  "description": "OpenCode plugin that syncs AI models from Synthetic to OpenCode, with optional Plexus integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.js && tsc --emitDeclarationOnly",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src test",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fredizzimo/opencode-synthetic-plexus.git"
  },
  "bugs": {
    "url": "https://github.com/fredizzimo/opencode-synthetic-plexus/issues"
  },
  "homepage": "https://github.com/fredizzimo/opencode-synthetic-plexus#readme",
  "keywords": [
    "opencode",
    "plugin",
    "synthetic",
    "plexus",
    "models"
  ],
  "author": "Fred Sundvik",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opencode-ai/plugin": "^1.3.6",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
